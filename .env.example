APP_ENV=development
APP_PORT=8000
DEBUG=true
LOG_LEVEL=DEBUG

ERPNEXT_BASE_URL=http://localhost:8080
ERPNEXT_API_KEY=test-api-key
ERPNEXT_API_SECRET=test-api-secret

AZURE_OCR_ENDPOINT=
AZURE_OCR_KEY=
OCR_PROVIDER=mock

DEFAULT_TENANT_ID=test-florist-001
# Use a comma-separated list in production. Keep "*" only for local development.
ALLOWED_ORIGINS=*

# Optional: force the mock OCR scenario during testing.
# OCR_MOCK_SCENARIO=standard

# Daily Close data source: mock (default) or erpnext
DAILY_CLOSE_DATA_SOURCE=mock

# Daily Close ERPNext credentials (used when DAILY_CLOSE_DATA_SOURCE=erpnext)
# DAILY_CLOSE_ERPNEXT_BASE_URL=http://localhost:8080
# DAILY_CLOSE_ERPNEXT_API_KEY=
# DAILY_CLOSE_ERPNEXT_API_SECRET=

# Optional Daily Close reconciliation inputs in real mode
# DAILY_CLOSE_OPENING_BALANCE=150
# DAILY_CLOSE_ACTUAL_CASH_COUNTED=195.5
# DAILY_CLOSE_POS_PROFILE=Floravi Shop 1
