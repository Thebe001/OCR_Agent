APP_ENV=development
APP_PORT=8000
DEBUG=true
LOG_LEVEL=DEBUG

ERPNEXT_BASE_URL=http://localhost:8080
ERPNEXT_API_KEY=test-api-key
ERPNEXT_API_SECRET=test-api-secret

AZURE_OCR_ENDPOINT=
AZURE_OCR_KEY=
